@{
    var currentPath = Context.Request.Path.ToString().ToLower();
    var isRegistrationOrAuthPage = currentPath == "/registration" || currentPath == "/auth";
    var isCatalogPage = currentPath.Contains("/catalog");
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/styles/layout.css" asp-append-version="true">
    <link rel="shortcut icon" href="~/static/main/Logo.svg" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Itim&family=Natasha:wght@700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@500;600&family=Inter:wght@400;500;600&family=Itim&display=swap" rel="stylesheet">
    <link href="https://fonts.cdnfonts.com/css/natasha" rel="stylesheet">
    @await RenderSectionAsync("Links", required: false)
</head>
<body>
    @Html.AntiForgeryToken()
    <header class="header py-2 sticky-top bg-white mb-0 p-3">
        <div class="container-fluid px-0">
            <div class="d-flex align-items-center">
                <!-- Меню -->
                <div class="left-section">
                    <button class="sticks" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
                        <img src="~/static/main/sticks.svg" asp-append-version="true" />
                    </button>

                    <!-- Логотип -->
                    <div class="logo" style="cursor: pointer">
                        <img src="~/static/main/Logo.svg" asp-append-version="true" onclick="location.href='/'" alt="Logo" width="65" height="42">
                    </div>
                </div>


                <!-- Кнопки для широких экранов -->
                <div class="right-section">
                    @if (!isRegistrationOrAuthPage && !isCatalogPage)
                    {
                        <div class="catalog-button" onclick="location.href='/catalog/1'">Каталог организаций</div>
                    }
                    @if (User!.Identity!.IsAuthenticated)
                    {
                        <div class="icon-block-header">
                            <img src="~/static/main/userIcon.svg" asp-append-version="true" onclick="redirectToProfile()" />
                            <div class="arrow-block">
                                <img src="~/static/main/arrow.svg" asp-append-version="true" class="arrow-icon" />
                                <div class="arrow-menu">
                                    <p onclick="logout()">Выход</p>
                                    <p class="change-button" data-bs-toggle="modal" data-bs-target="#changeModal">Сменить пароль</p>
                                </div>
                            </div>
                                
                        </div>
                    }
                    else if(!isRegistrationOrAuthPage)
                    {
                        <div class="auth-block-header">
                            <div class="login-button" data-bs-toggle="modal" data-bs-target="#loginModal">Вход</div>
                            <div class="register-button" onclick="location.href='/registration'">Регистрация</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Выезжающее меню -->
        <div class="offcanvas offcanvas-start" tabindex="-1" id="mobileMenu">
            <div class="offcanvas-header">
                <span class="offcanvas-title">Меню</span>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body">
                <button class="menu-button" onclick="location.href='/'">Главная страница</button>
                <button class="menu-button" onclick="location.href='/catalog/1'">Организации</button>
                <button class="menu-button" onclick="scrollToSection('footer')">Помощь</button>

                <!-- 🔽 этот блок будем обновлять -->
                <div class="auth-block mt-3"></div>
            </div>
        </div>
    </header>
    <div>
        @RenderBody()

        <!-- Модальное окно авторизации -->
        <div class="modal fade auth-window" id="loginModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0 auth-header">
                        <span class="modal-title auth-title">Авторизация</span>
                    </div>
                    <div class="modal-body">
                        <form class="auth-form" id="loginForm">
                            <div class="auth-fields">
                                <input id="email-auth" name="email" type="email" class="auth-field" placeholder="Электронная почта" required>
                                <div class="password-field">
                                    <div class="input-wrapper">
                                        <input id="password-auth" name="password" type="password" class="auth-field" placeholder="Пароль" required>
                                        <button type="button" class="password-toggle" data-target="password-auth">
                                            <img src="~/static/img/mdi_eye-outline.svg" asp-append-version="true" class="eye-icon" />
                                        </button>
                                    </div>
                                </div>
                                @* <span class="forgot-link" data-bs-target="#forgotModal" data-bs-toggle="modal" data-bs-dismiss="modal">Забыли пароль?</span> *@
                            </div>
                            <button type="submit" class="button-submit">Войти</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <!--Окно забыли пароль-->
        <div class="modal fade auth-window" id="forgotModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0 auth-header">
                        <span class="modal-title forgot-title">Восстановление пароля</span>
                    </div>
                    <div class="modal-body">
                        <form class="forgot-form" id="forgotForm">
                            <div class="auth-fields">
                                <input id="email-forgot" name="email" type="email" class="auth-field" placeholder="Электронная почта">
                                <span class="forgot-link" onclick="sendToken()">Получить код для восстановления</span>
                                <input id="token" name="token" class="auth-field" placeholder="Введите код"/>
                            </div>
                            <button type="submit" class="button-submit">Далее</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <!-- Модальное окно смены пароля-->
        <div class="modal fade change-window" id="changeModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0 auth-header">
                        <span class="modal-title auth-title">Смена пароля</span>
                    </div>
                    <div class="modal-body">
                        <form class="auth-form" id="changePasswordForm">
                            <div class="auth-fields">
                                <div class="field password-field">
                                    <div class="input-wrapper">
                                        <input type="password" class="auth-field" id="currentPassword" placeholder="Текущий пароль" required>
                                        <button type="button" class="password-toggle" data-target="currentPassword">
                                            <img src="~/static/img/mdi_eye-outline.svg" asp-append-version="true" class="eye-icon" />
                                        </button>
                                    </div>
                                </div>
                                <div class="field password-field">
                                    <div class="input-wrapper">
                                        <input type="password" class="auth-field" id="newPassword" placeholder="Новый пароль" required>
                                        <button type="button" class="password-toggle" data-target="newPassword">
                                            <img src="~/static/img/mdi_eye-outline.svg" asp-append-version="true" class="eye-icon" />
                                        </button>
                                    </div>
                                </div>
                                <div class="field password-field">
                                    <div class="input-wrapper">
                                        <input type="password" class="auth-field" id="confirmNewPassword" placeholder="Повторите новый пароль" required>
                                        <button type="button" class="password-toggle" data-target="confirmNewPassword">
                                            <img src="~/static/img/mdi_eye-outline.svg" asp-append-version="true" class="eye-icon" />
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <button type="submit" class="button-submit">Далее</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer id="footer">
            <div class="contacts">
                <span class="footer-title">Контакты</span>
            <div class="footer-item">
                    <img class="footer-icon" src="~/static/main/mail.svg" asp-append-version="true" />
                    <a href="mailto:yugolets@priazovsocialimpact.ru">yugolets@tmavt.ru</a>
                </div>
                <div class="footer-item">
                    <img class ="footer-icon" src="~/static/main/Phone.svg" asp-append-version="true" />
                    <a href="tel:+79185009038">+7 (918) 500-9039</a>
                </div>
            </div>
            <div class="help-section">
                <span class="help-title">Помощь?</span>
            <div class="footer-item">
                <img class="footer-icon" src="~/static/main/Telegram App.svg" asp-append-version="true" />
                <a href="https://t.me/yugolets" style="text-decoration: underline">yugolets</a>
            </div>
            </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // -------------------
            // Функции для работы с ошибками
            // -------------------
                function showError(message, formId = 'loginForm') {
                const form = document.getElementById(formId);
                if (!form) return;

                // Ищем или создаём контейнер ошибки
                let errorContainer = form.querySelector('.form-error');
    
                if (!errorContainer) {
                errorContainer = document.createElement('div');
                errorContainer.className = 'form-error';
                errorContainer.style.color = '#ff4444';
                errorContainer.style.textAlign = 'center';
                errorContainer.style.margin = '0 15px 20px';
                errorContainer.style.padding = '10px';
                errorContainer.style.backgroundColor = '#fff5f5';
                errorContainer.style.borderRadius = '5px';
                errorContainer.style.border = '1px solid #ff4444';
                errorContainer.style.fontSize = '14px';
                errorContainer.style.fontWeight = '500';

                // Вставляем перед кнопкой submit или в начало формы
                const submitButton = form.querySelector('button[type="submit"]');
                if (submitButton) {
                submitButton.parentNode.insertBefore(errorContainer, submitButton);
                } else {
                form.insertBefore(errorContainer, form.firstChild);
                }
                }

                errorContainer.textContent = message;
    
                // Автоматически скрываем через 5 секунд (опционально)
                setTimeout(() => {
                if (errorContainer?.parentNode) {
                errorContainer.remove();
                }
                }, 5000);
                }
        function initPasswordToggles() {
                const toggleButtons = document.querySelectorAll('.password-toggle');

                toggleButtons.forEach(button => {
                    // Удаляем старые обработчики чтобы избежать дублирования
                    button.replaceWith(button.cloneNode(true));
                });

                // Назначаем новые обработчики
                document.querySelectorAll('.password-toggle').forEach(button => {
                    button.addEventListener('click', function() {
                        const targetId = this.getAttribute('data-target');
                        const passwordInput = document.getElementById(targetId);
                        const eyeIcon = this.querySelector('.eye-icon');

                        if (!passwordInput || !eyeIcon) return;

                        if (passwordInput.type === 'password') {
                            passwordInput.type = 'text';
                            eyeIcon.src = '/static/img/mdi_eye-off-outline.svg';
                            eyeIcon.alt = 'Скрыть пароль';
                        } else {
                            passwordInput.type = 'password';
                            eyeIcon.src = '/static/img/mdi_eye-outline.svg';
                            eyeIcon.alt = 'Показать пароль';
                        }

                        // Обновляем версию для кэширования
                        const version = new Date().getTime();
                        eyeIcon.src = eyeIcon.src.split('?')[0] + '?v=' + version;
                    });
                });
            }
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const email = document.getElementById('email-auth').value;
            const password = document.getElementById('password-auth').value;

            loginUser(email, password);
        });

        async function loginUser(email, password) {
            const submitButton = document.querySelector('.button-submit');
            const originalText = submitButton.textContent;

            try {
                // Показываем индикатор загрузки
                submitButton.textContent = 'Вход...';
                submitButton.disabled = true;

                    console.log('Отправка запроса на /auth/login...');

            const response = await fetch('/auth/login', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    Email: email,
                    Password: password
                })
            });

            if (response.ok) {
                const data = await response.json();

                localStorage.setItem('accessToken', data.accessToken);
                localStorage.setItem('refreshToken', data.refreshToken);
                localStorage.setItem('user', JSON.stringify({
                    id: data.id,
                    role: data.role
                }));
                console.log('Успешный вход, пользователь:', data);

                // Закрываем модальное окно
                const modal = bootstrap.Modal.getInstance(document.getElementById('loginModal'));
                if (modal) {
                    modal.hide();
                }

                // Обновляем страницу (куки уже установлены сервером)
                window.location.href = `/account/${data.id}`;

            } else {
                // Ошибка от сервера - используем данные из data
                const data = await response.json();
                const errorMessage = data.message || data.title || 'Ошибка входа';
                console.error('Ошибка сервера:', errorMessage);
                showError(errorMessage);
            }

            } catch (error) {
                console.error('Ошибка при выполнении запроса:', error);
                showError('Ошибка сети или сервера: ' + error.message);
            } finally {
                submitButton.textContent = originalText;
                submitButton.disabled = false;
                }
        }

        document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const password = document.getElementById('currentPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const newPassword2 = document.getElementById('confirmNewPassword').value;

            // Очищаем предыдущие ошибки
            clearFieldError('newPassword');
            clearFieldError('confirmNewPassword');

            let hasErrors = false;

            if (newPassword.length < 8 || newPassword.length > 20) {
                showFieldError('newPassword', 'Пароль должен содержать от 8 до 20 символов!');
                hasErrors = true;
            }

            if (newPassword !== newPassword2) {
                showFieldError('confirmNewPassword', 'Пароли не совпадают!');
                hasErrors = true;
            }

            if (hasErrors) {
                return; // Не отправляем запрос если есть ошибки
            }

            resetPassword(password, newPassword, newPassword2);
        });

        async function resetPassword(password, newPassword, newPassword2) {
            const submitButton = document.querySelector('#changePasswordForm .button-submit');
            const originalText = submitButton.textContent;

            try {
                const user = JSON.parse(localStorage.getItem('user'));
                if (!user || !user.id) {
                    showError('Пользователь не авторизован');
                    return;
                }

                const userId = user.id;

                // Показываем индикатор загрузки
                submitButton.textContent = 'Сброс пароля...';
                submitButton.disabled = true;

                console.log('Отправка запроса на /password/change...');

                const response = await fetch('/password/change', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        UserId: userId,
                        Password: password,
                        NewPassword: newPassword,
                        NewPassword2: newPassword2
                    })
                });

                if (response.ok) {
                    console.log('Успешная смена пароля');

                    // Очищаем localStorage
                    localStorage.removeItem('user');
                    localStorage.removeItem('refreshToken');
                    localStorage.removeItem('accessToken');

                    // Закрываем модальное окно
                    const modal = bootstrap.Modal.getInstance(document.getElementById('changeModal'));
                    if (modal) {
                        modal.hide();
                    }

                    // Перенаправляем на главную
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 2000);

                } else {
                    // Обрабатываем ошибку
                    const data = await response.json();
                    const errorMessage = data.message || data.title || 'Ошибка при смене пароля';
                    console.error('Ошибка сервера:', errorMessage);
                    showError(errorMessage);
                }

            } catch (error) {
                console.error('Ошибка при выполнении запроса:', error);
                showError('Ошибка сети или сервера: ' + error.message);
            } finally {
                submitButton.textContent = originalText;
                submitButton.disabled = false;
            }
        }

        function redirectToProfile() {
            try {
                const user = JSON.parse(localStorage.getItem('user'));
                if (user && user.id) {
                    location.href = `/account/${user.id}`;
                } else {
                    // Если пользователь не авторизован, показываем модальное окно входа
                    const modal = new bootstrap.Modal(document.getElementById('loginModal'));
                    modal.show();
                }
            } catch (error) {
                console.error('Ошибка при получении данных пользователя:', error);
                // Показываем модальное окно входа при ошибке
                const modal = new bootstrap.Modal(document.getElementById('loginModal'));
                modal.show();
            }
        }
        async function logout() {
            try {
                const refreshToken = localStorage.getItem('refreshToken');
                const response = await fetch('/auth/logout', { // ← исправлен URL на /auth/logout
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        RefreshToken: refreshToken
                    })
                });

                if (response.ok) {
                    // Очищаем localStorage
                    localStorage.removeItem('user');
                    localStorage.removeItem('refreshToken');
                    localStorage.removeItem('accessToken');

                    // Перенаправляем на главную страницу
                    window.location.href = '/';
                } else {
                    console.error('Ошибка при выходе:', response.status);
                    // Даже при ошибке очищаем локальные данные
                    localStorage.removeItem('user');
                    window.location.href = '/';
                }
            } catch (error) {
                console.error('Ошибка при выходе:', error);
                // При любой ошибке очищаем локальные данные
                window.location.href = '/';
            }
        }
        function scrollToSection(sectionId) {
            const element = document.getElementById(sectionId);
            if (element) {
                element.scrollIntoView({
                    behavior: 'smooth'
                });
            }
            const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('mobileMenu'));
            if (offcanvas) {
                offcanvas.hide();
            }
        }
        // Функция для отправки кода восстановления
async function sendToken() {

    const email = document.getElementById('email-forgot').value;

    // Валидация email
    if (!email) {
        showAlert('Пожалуйста, введите email');
        return;
    }

    try {
        // Показываем индикатор загрузки
        showLoading(true);
        
        // Отправка запроса на бекенд
        const response = await fetch('/password/token', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({Email: email })
        });

        const result = await response.json();

        if (response.ok) {
            showAlert('Код отправлен на вашу почту', 'success');
            // Активируем поле для ввода кода
            document.getElementById('token').style.display = 'block';
        } else {
            showAlert(result.message || 'Ошибка при отправке кода');
        }
    } catch (error) {
        console.error('Ошибка:', error);
        showAlert('Произошла ошибка при отправке запроса');
    } finally {
        showLoading(false);
    }
}

// Функция для обработки отправки формы
async function handleForgotSubmit(event) {
    event.preventDefault();
    
    const email = document.getElementById('email-auth').value.trim();
    const token = document.getElementById('token').value.trim();

    // Валидация
    if (!email || !token) {
        showAlert('Пожалуйста, заполните все поля');
        return;
    }

    try {
        showLoading(true);
        
        // Отправка токена на проверку
        const response = await fetch('/api/auth/verify-reset-token', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ email, token })
        });

        const result = await response.json();

        if (response.ok) {
            // Если токен верный, закрываем текущее окно и открываем окно смены пароля
            closeForgotModal();
            openResetPasswordModal(email, token);
        } else {
            showAlert(result.message || 'Неверный код');
        }
    } catch (error) {
        console.error('Ошибка:', error);
        showAlert('Произошла ошибка при проверке кода');
    } finally {
        showLoading(false);
    }
}

// Функция для открытия модального окна смены пароля
function openResetPasswordModal(email, token) {
    // Закрываем текущее модальное окно
    const forgotModal = bootstrap.Modal.getInstance(document.getElementById('forgotModal'));
    forgotModal.hide();
    
    // Открываем окно смены пароля (должно быть в вашем HTML)
    const resetModal = new bootstrap.Modal(document.getElementById('resetPasswordModal'));
    resetModal.show();
    
    // Сохраняем данные для использования в следующем окне
    document.getElementById('resetPasswordModal').dataset.email = email;
    document.getElementById('resetPasswordModal').dataset.token = token;
}

// Функция закрытия модального окна восстановления
function closeForgotModal() {
    const modal = bootstrap.Modal.getInstance(document.getElementById('forgotModal'));
    modal.hide();
}

function showAlert(message, type = 'error') {
    if (type === 'error') {
        alert('Ошибка: ' + message);
    } else {
        alert(message);
    }
}

function showLoading(show) {
    // Реализация показа/скрытия индикатора загрузки
    const submitButton = document.querySelector('#forgotForm .button-submit');
    const sendTokenLink = document.querySelector('.forgot-link');
    
    if (show) {
        submitButton.disabled = true;
        sendTokenLink.style.pointerEvents = 'none';
        submitButton.textContent = 'Отправка...';
    } else {
        submitButton.disabled = false;
        sendTokenLink.style.pointerEvents = 'auto';
        submitButton.textContent = 'Далее';
    }
}

// Инициализация событий после загрузки DOM
document.addEventListener('DOMContentLoaded', function() {
    // Обработчик отправки формы
    const forgotForm = document.getElementById('forgotForm');
    if (forgotForm) {
        forgotForm.addEventListener('submit', handleForgotSubmit);
    }
    
    // Изначально скрываем поле для токена
    const tokenField = document.getElementById('token');
    if (tokenField) {
        tokenField.style.display = 'none';
    }
});
        initPasswordToggles()
    </script>
</body>
</html>
