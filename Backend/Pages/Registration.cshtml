@page
@model Backend.Pages.RegistrationModel
@{
    ViewData["Title"] = "Регистрация";
}
@section Links
{
    <link rel="stylesheet" href="~/styles/registrationPage.css" />
}


<!-- Основное содержимое -->
<main class="main-container">
    <h1 class="registration-title">регистрация</h1>
    <div class="registration-container">
        <div class="tabs-container">
            <button class="tab executor-tab">
                <span class="tab-text">исполнитель</span>
            </button>
            <button class="tab investor-tab">
                <span class="tab-text">инвестор</span>
            </button>
        </div>
        <form class="registration-form" method="post" name="myForm">
            <div class="form-field">
                <label asp-for="Company.Name"></label>
                <input asp-for="Company.Name" placeholder="краткое название организации" id="organizationName">
                <span asp-validation-for="Company.Name"></span>
            </div>
            <div class="form-field">
                <label asp-for="Company.FullAddress"></label>
                <input asp-for="Company.FullAddress" placeholder="юридический адрес" id="address">
                <span asp-validation-for="Company.FullAddress"></span>
            </div>
            <div class="form-field">
                <label asp-for="Company.Industry"></label>
                <input asp-for="Company.Industry" placeholder="сфера интересов" list="browsers" id="industry" >
                <span asp-validation-for="Company.Industry"></span>
                <datalist id="browsers">
                    <option value="" disabled selected hidden>категория (с выбором)</option>
                    <option value="Образовательное учреждение">Образовательное учреждение</option>
                    <option value="Научно-исследовательский институт">Научно-исследовательский институт</option>
                    <option value="Научно-образовательный проект">Научно-образовательный проект</option>
                    <option value="Государственное учреждение">Государственное учреждение</option>
                    <option value="Коммерческая деятельность">Коммерческая деятельность</option>
                    <option value="Стартап">Стартап</option>
                    <option value="Финансы">Финансы</option>
                    <option value="Акселератор / инкубатор / технопарк">Акселератор / инкубатор / технопарк</option>
                    <option value="Ассоциация / объединение">Ассоциация / объединение</option>
                    <option value="Инициатива">Инициатива</option>
                    <option value="Отраслевое событие / научная конференция">Отраслевое событие / научная конференция</option>
                    <option value="Другое">Другое</option>
                </datalist>
            </div>
            <div class="form-field">
                <label asp-for="Company.LeaderName"></label>
                <input asp-for="Company.LeaderName" placeholder="ФИО руководителя" id="FIO">
                <span asp-validation-for="Company.LeaderName"></span>
            </div>
            <div class="form-field">
                <label asp-for="Company.Phone"></label>
                <input asp-for="Company.Phone" id="phone" placeholder="7 (XXX) XXX-XX-XX" maxlength="20" required />
                <span asp-validation-for="Company.Phone"></span>
            </div>
            <div class="form-field">
                <label asp-for="Company.Email"></label>
                <input asp-for="Company.Email" placeholder="электронная почта" id="mail">
                <span asp-validation-for="Company.Email"></span>
            </div>
            <div class="form-field">
                <label asp-for="Company.Password"></label>
                <input asp-for="Company.Password" placeholder="пароль" id="password">
                <span asp-validation-for="Company.Password"></span>
            </div>
            <div class="form-field">
                <label asp-for="Company.Password2"></label>
                <input asp-for="Company.Password2" placeholder="повторите пароль" id="password2">
                <span asp-validation-for="Company.Password2"></span>
            </div>
            <button type="submit" class="submit-btn">Зарегистрироваться</button>
        </form>
    </div>
</main>

@section Scripts
{
    @* <script src="scripts/fetch.js" async></script> *@
}



