@page
@model Backend.IndexModel

@{
    ViewData["Organization"] = "организаций";
}
@if (Model.Count % 10 == 1)
{
    ViewData["Organization"] = "организация";
}
@if (Model.Count % 10 > 1 && Model.Count % 10 < 5)
{
    ViewData["Organization"] = "организации";
}
<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Проекты социального воздействия Приазовья</title>
    <link rel="stylesheet" href="~/styles/main.css" asp-append-version="true">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Itim&family=Natasha:wght@700&display=swap" rel="stylesheet">
</head>

<body>
    <header class="header">
        <div class="header-container">
            <div class="logo-group">
                <button class="menu-icon">
                    <div class="menu-icon-bar"></div>
                    <div class="menu-icon-bar"></div>
                    <div class="menu-icon-bar"></div>
                </button>
                <div class="logo">
                    <img width="65" height="42" viewBox="0 0 65 42" fill="none" src="static/main/Logo.svg">
                    <rect width="65" height="42" fill="#0E6466" />
                </div>
            </div>

            <div class="right-section">
                <div class="catalog-button">
                    <span>Каталог организаций</span>
                </div>
                <div class="login-button">
                    <span>Вход</span>
                </div>
                <div class="register-button" onclick="location.href='registration.html'">
                    <span>Регистрация</span>
                </div>
            </div>
        </div>
    </header>

    <!---->

    <main>
        <section class="hero-section">
            <div class="hero-container">
                <h1 class="hero-title">ПРОЕКТЫ СОЦИАЛЬНОГО ВОЗДЕЙСТВИЯ ПРИАЗОВЬЯ</h1>
            </div>
        </section>

        <section class="about-section">
            <div class="about-container">
                <button class="nav-button prev-button">
                    <div class="nav-icon">←</div>
                </button>
                <div class="about-card">
                    <div class="about-image">
                        <img src="static/main/Social-effect.svg" alt="#">
                    </div>
                    <div class="about-content">
                        <h2 class="about-title">Что такое проект социального воздействия?</h2>
                        <p class="about-text">
                            Проект социального воздействия — это комплекс мероприятий, направленных на достижение измеримого социального эффекта в жизни конкретных людей-участников проекта. Например, мероприятия по повышению успеваемости школьников на определенной территории или вовлечение людей в диспансеризацию, содействие в получении мер социальной поддержки.
                        </p>
                        <button class="about-button">Подробнее</button>
                    </div>
                </div>
                <button class="nav-button next-button">
                    <div class="nav-icon">→</div>
                </button>
            </div>
        </section>

        <section class="organizations-section">
            <div class="section-container">
                <div class="organizations-content">
                    <h2 class="section-title">ОРГАНИЗАЦИИ</h2>
                    <div class="map-filters-container">
                        <div class="map-container">
                            <script class="map-placeholder" type="text/javascript" charset="utf-8" async src="https://api-maps.yandex.ru/services/constructor/1.0/js/?um=constructor%3Abb2e803e8888540af1464fa8f0916b00692e5b83676a91f7a37ed16dc7f2b64b&amp;lang=ru_RU&amp;scroll=true" onload="initYandexMap(this)"></script>
                            <script src="scripts.js"></script>
                        </div>
                        <div class="filters-menu">
                            @Html.AntiForgeryToken()
                            <div class="filter-item">
                                <input type="checkbox" id="filter1" class="filter-checkbox">
                                <label for="filter1">Образовательное учреждение</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter2" class="filter-checkbox">
                                <label for="filter2">Научно-исследовательский институт</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter3" class="filter-checkbox">
                                <label for="filter3">Научно-образовательный проект</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter4" class="filter-checkbox">
                                <label for="filter4">Государственное учреждение</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter5" class="filter-checkbox">
                                <label for="filter5">Коммерческая деятельность</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter6" class="filter-checkbox">
                                <label for="filter6">Некоммерческая организация</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter7" class="filter-checkbox">
                                <label for="filter7">Финансы</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter8" class="filter-checkbox">
                                <label for="filter8">Акселератор / инкубатор / технопарк</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter9" class="filter-checkbox">
                                <label for="filter9">Ассоциация / объединение</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter10" class="filter-checkbox">
                                <label for="filter10">Инициатива</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter11" class="filter-checkbox">
                                <label for="filter11">Отраслевое событие / научная конференция</label>
                            </div>
                            <div class="filter-item">
                                <input type="checkbox" id="filter12" class="filter-checkbox">
                                <label for="filter12">Другое</label>
                            </div>
                        </div>
                    </div>


                    <!--Организации-->
                    <div class="organizations-grid">

                    @foreach (var company in Model.Query)
                    {
                            <div class="organization-card">
                                <div class="org-image"></div>
                                <h3 class="org-title">@company.Name</h3>
                                <p class="org-description">@company.Description</p>
                                <div class="org-details">
                                    <div class="detail">
                                        <span class="detail-icon">📍</span>
                                        <span class="detail-text">@company.FullAddress</span>
                                    </div>
                                    <div class="detail">
                                        <span class="detail-icon">🏛️</span>
                                        <span class="detail-text">@company.Industry</span>
                                    </div>
                                </div>
                            </div>
                    }

                        <div class="organization-card more-projects">
                            <div class="more-number">ЕЩЕ @Model.Count</div>
                            <div class="more-label">
                                @ViewData["Organization"]
                            </div>
                            <button class="view-all-button">Смотреть все</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="faq-section">
            <div class="section-container">
                <div class="faq-content">
                    <h2 class="section-title">Часто задаваемые вопросы</h2>
                    <div class="faq-list">
                        <div class="faq-item">
                            <div class="faq-question">
                                <span class="question-text">Что такое проект социального воздействия?</span>
                                <span class="farrow"></span>
                            </div>
                            <div class="faq-answer">
                                Очень важный ответ
                            </div>
                        </div>
                        <div class="faq-item">
                            <div class="faq-question">
                                <span class="question-text">Роль ВЭБ.РФ</span>
                                <span class="farrow"></span>
                            </div>
                            <div class="faq-answer">
                                Очень важный ответ
                            </div>
                        </div>
                        <div class="faq-item">
                            <div class="faq-question">
                                <span class="question-text">Нормативная база</span>
                                <span class="farrow"></span>
                            </div>
                            <div class="faq-answer">
                                Очень важный ответ
                            </div>
                        </div>
                        <div class="faq-item">
                            <div class="faq-question">
                                <span class="question-text">Примеры успешных проектов</span>
                                <span class="farrow"></span>
                            </div>
                            <div class="faq-answer">
                                Очень важный ответ
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer>
        <div class="contacts">
            <h3>Контакты</h3>
            <div class="contact-item">
                <span>✉</span>
                <a href="mailto:yugolets@priazovsocialimpact.ru" style="color: white; text-decoration: none">yugolets@priazovsocialimpact.ru</a>
            </div>
            <div class="contact-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20.487 17.14L18.387 15.79C17.447 15.15 16.217 15.41 15.587 16.34L14.517 17.95C12.997 17.35 9.66705 14.33 9.03705 12.81L10.647 11.75C11.587 11.12 11.847 9.89 11.207 8.95L9.85705 6.85C9.21705 5.91 7.98705 5.66 7.05705 6.29L4.50705 8.09C3.57705 8.72 3.32705 9.96 3.96705 10.89L5.72705 13.9C7.96705 18.22 11.647 21.43 16.187 22.71C16.967 22.93 17.787 22.71 18.337 22.11L20.337 19.91C21.107 19.03 20.997 17.67 20.487 17.14Z" fill="currentColor" />
                </svg>
                <a href="callto:+79185009038" style="color: white; text-decoration: none">+7 (918) 500-9039</a>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const faqItems = document.querySelectorAll('.faq-item');

            faqItems.forEach(item => {
                const question = item.querySelector('.faq-question');
                const arrow = item.querySelector('.farrow');

                question.addEventListener('click', () => {
                    // Закрываем все открытые элементы, кроме текущего
                    faqItems.forEach(otherItem => {
                        if (otherItem !== item && otherItem.classList.contains('active')) {
                            otherItem.classList.remove('active');
                            otherItem.querySelector('.farrow').classList.remove('farrow-rotated');
                        }
                    });

                    // Переключаем текущий элемент
                    item.classList.toggle('active');
                    arrow.classList.toggle('farrow-rotated');
                });
            });
        });

            document.querySelectorAll('.filter-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const label = document.querySelector(`label[for="${this.id}"]`);

                if (label) {
                    const labelText = label.textContent.trim();
                    const isChecked = this.checked;

                    console.log(`Чекбокс "${labelText}" - ${isChecked ? 'выбран' : 'не выбран'}`);

                    updateServerSelection(labelText, isChecked);
                }
            });
        });

        function updateServerSelection(labelText, isChecked) {
            const data = {
                Industry: labelText,
                IsChecked: isChecked
            };

            fetch('/?handler=UpdateFilter', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(data)
            })
            .then(response => {
                if (!response.ok) {
                    console.error('Ошибка при отправке данных');
                }
            });
        }
    </script>

</body>

</html>
