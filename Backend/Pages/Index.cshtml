@page
@model Backend.IndexModel

@{
    ViewData["Organization"] = "организаций";
    ViewData["Title"] = "Проекты социального воздействия Приазовья";
}
@if (Model.Count % 10 == 1 && (Model.Count % 100 < 10 || Model.Count % 100 > 20))
{
    ViewData["Organization"] = "организация";
}
@if (Model.Count % 10 > 1 && Model.Count % 10 < 5 && (Model.Count % 100 < 10 || Model.Count % 100 > 20))
{
    ViewData["Organization"] = "организации";
}
@section Links
{
    <link rel="stylesheet" href="~/styles/main.css" asp-append-version="true">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Itim&family=Natasha:wght@700&display=swap" rel="stylesheet">
}

<main>
    <section class="hero-section">
        <div class="hero-container">
            <h1 class="hero-title">@ViewData["Title"]!.ToString()!.ToUpper()</h1>
        </div>
    </section>

    <section class="about-section">
        <div class="about-container">
            <div class="about-card">
                <div class="about-image">
                    <img src="static/main/Social-effect.svg" alt="#">
                </div>
                <div class="about-content">
                    <h2 class="about-title">Что такое проект социального воздействия?</h2>
                    <p class="about-text">
                        Проект социального воздействия — это комплекс мероприятий, направленных на достижение измеримого социального эффекта в жизни конкретных людей-участников проекта. Например, мероприятия по повышению успеваемости школьников на определенной территории или вовлечение людей в диспансеризацию, содействие в получении мер социальной поддержки.
                    </p>
                    <button onclick="scrollToSection('faq-section')" class="about-button">Подробнее</button>
                </div>
            </div>
        </div>
    </section>

    <section class="organizations-section">
        <div class="section-container">
            <div class="organizations-content">
                <h2 class="section-title">ОРГАНИЗАЦИИ</h2>
                <div class="map-filters-container">
                    <div class="map-container">
                        <div id="map" class="map-placeholder"></div>
                    </div>
                    <div class="filters-menu">
                        @Html.AntiForgeryToken()

                        <label class="filter-item">
                            <input type="checkbox" id="filter1" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Образовательное учреждение</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter2" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Научно-исследовательский институт</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter3" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Научно-образовательный проект</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter4" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Государственное учреждение</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter5" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Коммерческая деятельность</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter6" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Некоммерческая организация</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter7" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Финансы</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter8" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Акселератор / инкубатор / технопарк</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter9" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Ассоциация / объединение</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter10" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Инициатива</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter11" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Отраслевое событие / научная конференция</span>
                        </label>

                        <label class="filter-item">
                            <input type="checkbox" id="filter12" class="filter-checkbox">
                            <span class="checkmark"></span>
                            <span class="filter-text">Другое</span>
                        </label>
                    </div>
                </div>

                <!--Организации-->
                <div class="organizations-grid">

                    @for (int i = 0; i < Model.Query.Count; i++)
                    {
                        <div class="organization-card" onclick="location.href='/account/@Model.Query[i].Id'">
                            <img class="org-image" src="@Model.Images[i]" asp-append-version="true">
                            <div class="org-text">
                                <h3 class="org-title">@Model.Query[i].Name</h3> <!--Problem zone-->
                                <p class="org-description">@Model.Query[i].Description</p>
                            </div>
                            <div class="org-details">
                                <div class="detail">
                                    <span class="detail-icon"><img src="~/static/img/location_on.svg" asp-append-version="true" /></span>
                                    <span class="detail-text">@Model.Query[i].FullAddress</span>
                                </div>
                                <div class="detail">
                                    <span class="detail-icon"><img src="~/static/img/gmail_groups.svg" asp-append-version="true" /></span>
                                    <span class="detail-text">@Model.Query[i].Industry</span>
                                </div>
                            </div>
                        </div>
                    }
                    @if (Model.Count > 0)
                    {
                        <div class="organization-card more-projects" onclick="location.href='/catalog'">
                            <div class="more-text">
                                <span class="more-number">
                                    ЕЩЕ <span style="font-family: 'Natasha', sans-serif;
                                        font-weight: 400;
                                        font-size: 52px;
                                        line-height: 120%;
                                        letter-spacing: 0%;">@Model.Count</span>
                                </span>
                                <span class="more-label">@ViewData["Organization"]</span>
                            </div>
                            <button class="view-all-button" onclick="location.href='/catalog'">Смотреть все</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="faq-section" id="faq-section">
                <h2 class="faq-title">Часто задаваемые вопросы</h2>
                    <div class="faq-item">
                        <div class="faq-question">
                            <span class="question-text">Что такое проект социального воздействия?</span>
                            <span class="farrow"></span>
                        </div>
                        <div class="faq-answer">
                Проект социального воздействия — это комплекс мероприятий, направленных на достижение измеримого социального эффекта в жизни конкретных людей-участников проекта. Например, мероприятия по повышению успеваемости школьников на определенной территории или вовлечение людей в диспансеризацию, содействие в получении мер социальной поддержки.
            </div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">
                            <span class="question-text">Роль ВЭБ.РФ</span>
                            <span class="farrow"></span>
                        </div>
                        <div class="faq-answer">
                ВЭБ.РФ при методологической поддержке Минфина России выступает оператором проектов: помогает регионам, инвесторам и исполнителям в структурировании проектов, мониторинге достижения эффектов реализации проектов и их независимой оценке. Также задача ВЭБ.РФ - способствовать масштабированию успешных практик.
            </div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">
                            <span class="question-text">Нормативная база</span>
                            <span class="farrow"></span>
                        </div>
                        <div class="faq-answer">
                <p><a href="https://вэб.рф/files/?file=b80cc6857acc7f13d4ff3116a5f9a5d3.pdf" target="_blank">Постановление Правительства РФ от 21.11.2019 г. №1491 «Об&nbsp;организации проведения субъектами РФ в 2019–2024 годах пилотной апробации проектов социального воздействия»</a></p>
                <p><a href="https://вэб.рф/files/?file=0f7890fd21e47b7a68b06e2f8b8ea134.pdf" target="_blank">Распоряжение от 26.12.2023 № Р-1337 «Об&nbsp;утверждении Регламента принятия ВЭБ.РФ решений об осуществлении функции оператора проектов социального воздействия»</a></p>
                <p><a href="https://вэб.рф/files/?file=c0363d34f8db412db87d351839dc2bed.pdf" target="_blank">Распоряжение от 23.12.2021 Р-1086 «Об утверждении порядка проведения мониторинга и итоговой формы отчета»</a></p>

            </div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">
                            <span class="question-text">Примеры успешных проектов</span>
                            <span class="farrow"></span>
                        </div>
                        <div class="faq-answer">
                            <a href="https://вэб.рф/agent-pravitelstva/psv/socialnye-proekty/" target="_blank">Реализованные проекты социального воздействия</a>
                        </div>
                    </div>
    </section>
</main>

@section Scripts
{
    <script src="https://api-maps.yandex.ru/2.1/?apikey=79291f02-351a-4139-9402-f2037856fba7&lang=ru_RU" type="text/javascript"></script>



    <script>
        function scrollToSection(sectionId) {
            const element = document.getElementById(sectionId);
            if (element) {
                element.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        }
                document.addEventListener('DOMContentLoaded', function() {
            const faqItems = document.querySelectorAll('.faq-item');

            faqItems.forEach(item => {
                const question = item.querySelector('.faq-question');
                const arrow = item.querySelector('.farrow');

                question.addEventListener('click', () => {
                    item.classList.toggle('active');
                    arrow.classList.toggle('farrow-rotated');
                });
            });
        });

        // Выносим переменные карты в глобальную область видимости
        let myMap;
        let clusterer;

        ymaps.ready(init);

        function init() {

        myMap = new ymaps.Map("map", {
            center: [47.2225, 39.7186],
            zoom: 12
        }, {
            controls: [],
            suppressMapOpenBlock: true,
            suppressObsoleteBrowserNotifier: true,
            yandexMapDisablePoiInteractivity: true
        });

        myMap.controls.remove('searchControl');
        myMap.controls.remove('trafficControl');
        myMap.controls.remove('geolocationControl');
        myMap.controls.remove('typeSelector');
        myMap.controls.remove('fullscreenControl');
        myMap.controls.remove('routeButtonControl');
        myMap.controls.remove('rulerControl');
        myMap.controls.remove('zoomControl');

        myMap.behaviors.disable('all');

            setTimeout(() => {
            if (myMap) {
                myMap.container.fitToViewport();
            }
        }, 1000);

            // Инициализируем кластеризатор
            clusterer = new ymaps.Clusterer({
            preset: 'islands#greenClusterIcons', // Базовый зеленый
            clusterIconColor: '#0E6466' // Ваш цвет
            });
            myMap.geoObjects.add(clusterer);

            // Первоначальная загрузка меток
            updateServerSelection();
        }

        // Функция для обновления меток на карте
        function updateMapMarkers(addresses) {
            // Очищаем текущие метки
            myMap.geoObjects.removeAll();
            clusterer.removeAll();
            
            const geoObjects = addresses.map(location => {
                let name = "";
                for (const company of location.companies)
                {
                    name += company.name + ",\n";
                }
                return new ymaps.Placemark(
                    [location.address.latitude, location.address.longitude],
                    {

                        balloonContentHeader: `<div style="font-size: 16px;
                        font-family: "Fira Code", monospace;
                        font-weight: 500;
                        line-height: 120%;
                        letter-spacing: 4%;
                        margin-bottom: 10px;">${name.slice(0, -2)}</div>`,
        balloonContentBody: `
            <div style="max-height: 200px; overflow-y: auto;">
                    <div style="    font-family: 'Inter', sans-serif;
                    font-weight: 400;
                    font-size: 16px;
                    line-height: 130%;
                    letter-spacing: 4%;
                    margin-bottom: 10px;
                    color: #666;">
                    Найдено компаний: <span>${location.companies.length}</span>
                </div>
                <div style="border-top: 1px solid #eee; padding-top: 10px;">
                    ${location.companies.map((company, index) =>
                        `<div style="padding: 5px 0; border-bottom: 1px solid #f5f5f5;">
                            ${index + 1}. ${company.name}
                         </div>`
                    ).join('')}
                </div>
            </div>
        `,
        hintContent: `Компании: ${location.companies.length}`
                    },
                    {
                        preset: 'islands#darkGreenCircleIcon',
                        iconColor: '#0E6466'
                    }
                );
            });

            // Добавляем новые метки на карту
            clusterer.add(geoObjects);

            myMap.geoObjects.add(clusterer);

            // Автоматически подбираем масштаб
            if (geoObjects.length > 0) {
                myMap.setBounds(clusterer.getBounds(), {
                    checkZoomRange: true,
                    zoomMargin: 50
                });
            };
        }

        document.querySelectorAll('.filter-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const allCheckboxesData = Array.from(document.querySelectorAll('.filter-checkbox')).map(checkbox => {
                const filterText = checkbox.closest('.filter-item').querySelector('.filter-text');
                return {
                    Industry: filterText ? filterText.textContent.trim() : '',
                    IsChecked: checkbox.checked
                };
                });

                console.log('Текущее состояние всех чекбоксов:', allCheckboxesData);
                updateServerSelection(allCheckboxesData);
            });
        });

        function updateServerSelection(allCheckboxesData) {

            fetch('/?handler=UpdateFilter', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(allCheckboxesData)
            })
            .then(response => {
                if (!response.ok) {
                    console.error('Ошибка при отправке данных');
                }
                return response.json();
            })
            .then(data => {
                updateMapMarkers(data);
            });
        }
    </script>
}


