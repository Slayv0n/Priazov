@page "/forgot_password"
@model Backend.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Вход";
}
@section Links
{
    <link rel="stylesheet" href="~/styles/fogrotPassword.css" asp-append-version="true" />
}

<main class="main-container">

    <div class="auth-container">
        <h1 class="auth-title">@ViewData["Title"]</h1>
        <form class="email-form" asp-page="ForgotPassword" asp-page-handler="Email">
            <div class="field">
                <label>Электронная почта</label>
                <div class="form-field">
                    <input placeholder="Электронная почта" type="email" id="email">
                </div>
                <span id="emailValidate" class="validate"></span>
            </div>
            @if(Model.IsTokenSend)
            {
                <div class="send">
                    Вам на указанную почту было отправленно письмо с кодом для восстановления пароля.
                </div>
            }
            else
            {
                <div class="forgot" align="center">
                    <button class="code-button" type="submit">Получить код для восстановления</button>
                </div>
            }
            

        </form>
        <form class="token-form" asp-page="ForgotPassword" asp-page-handler="Token">

            <div class="field">
                <label ></label>
                <div class="form-field">
                    <input placeholder="Введите код" id="email">
                </div>
                <span class="validate"></span>
            </div>

            <span class="validate">@Model.ValidationResult</span>

            <button type="submit" class="submit-btn">Далее</button>
        </form>
    </div>
</main>

@section Scripts {
<script>
                document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('.email-form');

            // Функция таймера
            function startCountdown(email) {
                const timerContainer = document.getElementById('timer-container');
                const countdownElement = document.getElementById('countdown');
                let countdown = 60;

                timerContainer.style.display = 'block';

                const timer = setInterval(function() {
                    countdown--;
                    countdownElement.textContent = countdown;

                    if (countdown <= 0) {
                        clearInterval(timer);
                        timerContainer.style.display = 'none';

                        // Восстанавливаем исходную форму
                        const formContainer = document.querySelector('.email-form');
                        formContainer.innerHTML = `
                            <form class="email-form" asp-page="ForgotPassword" asp-page-handler="Email">
                                <div class="field">
                                    <label>Электронная почта</label>
                                    <div class="form-field">
                                        <input id="email" value="${email}">
                                    </div>
                                </div>
                                <div class="forgot" align="center">
                                    <button class="code-button" type="submit">Получить код для восстановления</button>
                                </div>
                            </form>
                        `;

                        // Регистрируем обработчик снова
                        setupFormSubmit();
                    }
                }, 1000);
            }

            // Функция для настройки обработчика формы
            function setupFormSubmit() {
                document.querySelector('.email-form')?.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    const form = e.target;
                    const submitButton = form.querySelector('button[type="submit"]');
                    const email = form.querySelector('#email').value;
                    const validationSpan = form.querySelector('.validate');

                    submitButton.disabled = true;
                    submitButton.innerHTML = 'Отправка...';

                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                        const response = await fetch(form.action, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({ Email: email })
                        });

                        if (response.ok) {
                            const result = await response.json();

                            if (result.success) {
                                form.innerHTML = `
                                    <div class="field">
                                        <label>Электронная почта</label>
                                        <div class="form-field">
                                            <input value="${email}" readonly>
                                        </div>
                                    </div>
                                    <div class="send">
                                        <p>Вам на указанную почту было отправлено письмо с кодом для восстановления пароля.</p>
                                    </div>
                                    <div id="timer-container" style="display: none;">
                                        <p>Повторная отправка кода будет доступна через: <span id="countdown">60</span> сек.</p>
                                    </div>
                                `;

                                // Запускаем таймер
                                startCountdown(email);
                            } else {
                                if (result.errors?.Email) {
                                    validationSpan.textContent = result.errors.Email[0];
                                }
                            }
                        } else {
                            throw new Error('Ошибка сервера: ' + response.status);
                        }
                    } catch (error) {
                        console.error('Ошибка:', error);
                        alert('Произошла ошибка при отправке формы');
                    } finally {
                        submitButton.disabled = false;
                        if (submitButton) {
                            submitButton.innerHTML = 'Получить код для восстановления';
                        }
                    }
                });
            }

            // Инициализация при загрузке
            setupFormSubmit();
        });
                 
        
</script>
}