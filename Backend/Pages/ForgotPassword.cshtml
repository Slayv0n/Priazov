@page "/forgot_password"
@model Backend.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Забыли пароль?";
}
@section Links
{
    <link rel="stylesheet" href="~/styles/fogrotPassword.css" asp-append-version="true" />
}

<main class="main-container">
    <div class="auth-container">
        <h1 class="auth-title">@ViewData["Title"]</h1>

        <!-- Форма для email -->
        <form class="email-form" method="post" asp-page-handler="Email">
            @Html.AntiForgeryToken()
            <div class="field">
                <label>Электронная почта</label>
                <div class="form-field">
                    <input placeholder="Электронная почта" type="email" id="email"
                           name="Email">
                </div>
                <span id="emailValidate" class="validate"></span>
            </div>
            <div class="forgot" align="center">
                <button class="code-button" type="submit">Получить код для восстановления</button>
            </div>
        </form>

        <!-- Форма для токена -->
        <form class="token-form" method="post" asp-page-handler="Token">
            @Html.AntiForgeryToken()
            <div class="field">
                <label>Код подтверждения</label>
                <div class="form-field">
                    <input placeholder="Введите код" id="token"
                           name="Token">
                </div>
                <span class="validate"></span>
            </div>

            <span class="validate">@Model.ValidationResult</span>

            <button type="submit" class="submit-btn">Далее</button>
        </form>
    </div>
</main>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Основная функция инициализации
        function initializeForms() {
            // Обработка формы email
            const emailForm = document.querySelector('.email-form');
            if (emailForm) {
                emailForm.addEventListener('submit', handleEmailSubmit);
            }

            // Обработка формы токена
            const tokenForm = document.querySelector('.token-form');
            if (tokenForm) {
                tokenForm.addEventListener('submit', handleTokenSubmit);
            }
        }

        // Обработчик отправки email
        async function handleEmailSubmit(e) {
            e.preventDefault();
            
            const form = e.target;
            const submitButton = form.querySelector('button[type="submit"]');
            const validationSpan = form.querySelector('#emailValidate');
            const emailInput = form.querySelector('#email');
            const email = emailInput.value;

            // Показываем "Отправка..."
            const originalText = submitButton.innerHTML;
            submitButton.disabled = true;
            submitButton.innerHTML = 'Отправка...';

            try {
                const formData = new FormData(form);
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': formData.get('__RequestVerificationToken')
                    },
                    body: JSON.stringify({ Email: formData.get('Email') })
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        // Заменяем форму на сообщение об успехе
                        form.innerHTML = `
                            <div class="field">
                                <label>Электронная почта</label>
                                <div class="form-field">
                                    <input value="${email}" readonly>
                                </div>
                            </div>
                            <div class="send">
                                <p>Вам на указанную почту было отправлено письмо с кодом для восстановления пароля.</p>
                            </div>
                            <div id="timer-container" style="display: block;">
                                <p>Повторная отправка кода будет доступна через: <span id="countdown">60</span> сек.</p>
                            </div>
                        `;
                        
                        // Запускаем таймер
                        startCountdown(email);
                    } else {
                        validationSpan.textContent = result.error || 'Ошибка отправки';
                    }
                } else {
                    throw new Error('Ошибка сервера: ' + response.status);
                }
            } catch (error) {
                console.error('Ошибка:', error);
                validationSpan.textContent = 'Произошла ошибка при отправке';
            } finally {
                // Восстанавливаем кнопку
                submitButton.disabled = false;
                submitButton.innerHTML = originalText;
            }
        }

        // Обработчик отправки токена
        async function handleTokenSubmit(e) {
            e.preventDefault();
            
            const form = e.target;
            const submitButton = form.querySelector('button[type="submit"]');
            const validationSpan = form.querySelector('.validate');

            // Показываем "Проверка..."
            const originalText = submitButton.innerHTML;
            submitButton.disabled = true;
            submitButton.innerHTML = 'Проверка...';

            try {
                const formData = new FormData(form);
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': formData.get('__RequestVerificationToken')
                    },
                    body: JSON.stringify({ Token: formData.get('Token') })
                });

                if (response.redirected) {
                    window.location.href = response.url;
                } else if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        window.location.href = result.redirectUrl || '/reset_password';
                    } else {
                        validationSpan.textContent = result.error || 'Неверный код';
                    }
                }
            } catch (error) {
                console.error('Ошибка:', error);
                validationSpan.textContent = 'Ошибка проверки кода';
            } finally {
                // Восстанавливаем кнопку
                submitButton.disabled = false;
                submitButton.innerHTML = originalText;
            }
        }

        // Функция таймера
        function startCountdown(email) {
            const timerContainer = document.getElementById('timer-container');
            const countdownElement = document.getElementById('countdown');
            let countdown = 60;

            const timer = setInterval(function() {
                countdown--;
                countdownElement.textContent = countdown;

                if (countdown <= 0) {
                    clearInterval(timer);
                    timerContainer.style.display = 'none';

                    // Восстанавливаем исходную форму
                    const formContainer = document.querySelector('.email-form');
                    formContainer.innerHTML = `
                        <form class="email-form" method="post" asp-page-handler="Email">
                            @Html.AntiForgeryToken()
                            <div class="field">
                                <label>Электронная почта</label>
                                <div class="form-field">
                                    <input placeholder="Электронная почта" type="email" 
                                           id="email" name="Email" value="${email}">
                                </div>
                                <span id="emailValidate" class="validate"></span>
                            </div>
                            <div class="forgot" align="center">
                                <button class="code-button" type="submit">Получить код для восстановления</button>
                            </div>
                        </form>
                    `;

                    // Переинициализируем обработчики
                    initializeForms();
                }
            }, 1000);
        }

        // Инициализируем формы при загрузке
        initializeForms();
    });
</script>
}
